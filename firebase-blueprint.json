{
  "entities": {
    "Contact": {
      "title": "Contact Form Submission",
      "description": "A submission from the contact form",
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "description": "First name of the sender"
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the sender"
        },
        "email": {
          "type": "string",
          "description": "Email address of the sender"
        },
        "service": {
          "type": "string",
          "description": "Service requested"
        },
        "details": {
          "type": "string",
          "description": "Project details or message"
        },
        "createdAt": {
          "type": "timestamp"
        }
      },
      "required": ["firstName", "lastName", "email", "service", "details", "createdAt"]
    }
  },
  "firestore": {
    "contacts": {
      "schema": "Contact",
      "description": "A collection of contact form submissions"
    }
  }
}
